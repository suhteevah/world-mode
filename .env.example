# World Mode Environment Variables
# Copy to .env and fill in values

# No API key needed — Claude Code handles auth via OAuth
# No Python needed — pure Rust + Lua

# Factorio Server RCON
FACTORIO_RCON_HOST=127.0.0.1
FACTORIO_RCON_PORT=27015
